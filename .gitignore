.idea/
*.iml
*.iws
*.ipr
# PyCharm shelve、workspace等临时文件
/shelf/
/workspace.xml
# HTTP请求文件
/httpRequests/
# 数据库数据源配置
/dataSources/
/dataSources.local.xml

# ====================== Python 环境与缓存 ======================
# Python字节码缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
# 虚拟环境（覆盖所有常见命名）
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
# 环境变量文件
.env
.env.*

# ====================== 机器学习/计算机视觉专属 ======================
